@model IEnumerable<MemberForSessionViewModel>

@{
    ViewData["Title"] = "Member for ongoing session";
}

@* تأكد أن الـ Alert بداخل div له id="Alert" لو البارشيال مش بيعمل ده *@
<div id="Alert">
    <partial name="_Alert" />
</div>

<header class="bg-primary text-white rounded-3 p-4 shadow-sm mt-5 mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="mb-1 fw-semibold">Session Members</h2>
            <p class="mb-0 text-light opacity-75">Manage Attendance</p>
        </div>
        <a asp-action="Index" class="btn btn-light btn-sm shadow-sm">
            <i class="bi bi-arrow-left"></i> Back to Sessions
        </a>
    </div>
</header>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @* p-0 عشان الجدول ياخد المساحة كاملة وشكله يبقى أنضف *@
        @if (Model is not null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle text-center mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="py-3">Member Name</th>
                            <th class="py-3">Attendance Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var member in Model)
                        {
                            <tr>
                                <td class="fw-medium">@member.MemberName</td>
                                <td>
                                    @if (member.IsAttended)
                                    {
                                        <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill">
                                            <i class="bi bi-check-lg me-1"></i> Attended
                                        </span>
                                    }
                                    else
                                    {
                                        <form asp-action="Attended" method="post" class="d-inline">
                                            <input type="hidden" value="@member.MemberId" name="MemberId" />
                                            <input type="hidden" value="@member.SessionId" name="SessionId" />
                                            <button type="submit" class="btn btn-success btn-sm px-3 rounded-pill shadow-sm">
                                                <i class="bi bi-person-check me-1"></i> Mark Present
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-people text-muted display-1"></i>
                <h4 class="mt-3 text-muted">No members booked for this session.</h4>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // بنحاول نجيب الـ alert سواء كان الـ ID في البارشيال أو الأب
            const alertBox = document.querySelector(".alert") || document.getElementById("Alert");
            if (alertBox) {
                setTimeout(() => {
                    alertBox.style.transition = "opacity 0.5s ease";
                    alertBox.style.opacity = "0";
                    setTimeout(() => alertBox.remove(), 500);
                }, 2500); // زودت الوقت شوية عشان اليوزر يلحق يقرأ
            }
        });
    </script>
}